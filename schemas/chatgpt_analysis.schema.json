{
  "title": "AI Newspaper ChatGPT Analysis Output",
  "type": "object",
  "required": ["edition_id", "topics"],
  "additionalProperties": false,
  "properties": {
    "edition_id": { "type": "string", "minLength": 1 },
    "edition_label": { "type": "string" },
    "generated_at_jst": { "type": "string" },
    "topics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["topic_id", "headline", "what_happened", "why_it_matters", "key_facts", "perspectives", "uncertainties", "source_refs"],
        "additionalProperties": false,
        "properties": {
          "topic_id": { "type": "string", "minLength": 1 },
          "category": { "type": "string" },
          "headline": { "type": "string", "minLength": 1 },
          "what_happened": { "type": "string", "minLength": 20 },
          "why_it_matters": { "type": "string", "minLength": 20 },
          "key_facts": { "type": "array", "items": { "type": "string" } },
          "perspectives": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["persona", "analysis"],
              "additionalProperties": false,
              "properties": {
                "persona": { "type": "string" },
                "analysis": { "type": "string" }
              }
            }
          },
          "forecast": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enabled": { "type": "boolean" },
              "one_week": { "type": "string" },
              "one_month": { "type": "string" },
              "conditions": { "type": "array", "items": { "type": "string" } }
            }
          },
          "business_explainer": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enabled": { "type": "boolean" },
              "why_notable": { "type": "string" },
              "business_impact": { "type": "string" },
              "beginner_checks": { "type": "array", "items": { "type": "string" } }
            }
          },
          "uncertainties": { "type": "array", "items": { "type": "string" } },
          "source_refs": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
